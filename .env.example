# ===== Banco de dados =====
DATABASE_URL=postgresql://usuario:senha@host:5432/audira

# ===== Anthropic (Claude) =====
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ===== DJEN / Comunica API (CNJ) =====
DJEN_BASE_URL=https://comunicaapi.pje.jus.br/api/v1
# OABs monitoradas (formato: numero-UF, separadas por virgula)
OABS_MONITORADAS=12345-PB,67890-PB

# ===== n8n (encanacao: WhatsApp, Zoom) =====
# URL do webhook do n8n que envia mensagens / cria eventos
N8N_WEBHOOK_URL=https://seu-n8n.exemplo.com/webhook/audira

# ===== Twilio WhatsApp (teste com numero real) =====
# Se preenchido, o app envia direto pelo Twilio (em vez do n8n).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Numero do Sandbox, no formato whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=

# ===== Servidor =====
PORT=3000

# ===== Escritório =====
# Telefone de contato exibido nas mensagens ao cliente
ESCRITORIO_TELEFONE=(83) 0000-0000
